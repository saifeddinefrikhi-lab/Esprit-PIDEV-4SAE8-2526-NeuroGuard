pipeline {
    agent any

    triggers {
        githubPush()
    }

    environment {
        GIT_REPO       = 'https://github.com/saifeddinefrikhi-lab/Esprit-PIDEV-4SAE8-2526-NeuroGuard.git'
        GIT_BRANCH     = 'main'
        SONAR_TOKEN    = credentials('sonar-token')
        DOCKER_IMAGE   = "neuroguard/frontend"
        DOCKER_TAG     = "${env.BUILD_NUMBER}"
        SERVICE_DIR    = "FrontEnd"
    }

    options {
        timeout(time: 45, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        stage('Code Checkout') {
            steps {
                git branch: "${GIT_BRANCH}",
                    url: "${GIT_REPO}"
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npm ci --legacy-peer-deps'
                }
            }
        }

        stage('Karma Unit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh '''
                        export DISPLAY=:99
                        Xvfb :99 -screen 0 1024x768x24 &
                        npx ng test \
                            --watch=false \
                            --browsers=ChromeHeadlessNoSandbox \
                            --code-coverage
                    '''
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "${SERVICE_DIR}/test-results/karma-results.xml"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            sonar-scanner \
                                -Dsonar.projectKey=neuroguard-frontend \
                                -Dsonar.projectName="NeuroGuard - Angular Frontend" \
                                -Dsonar.sources=src \
                                -Dsonar.tests=src/__tests__ \
                                -Dsonar.typescript.lcov.reportPaths=coverage/lcov.info \
                                -Dsonar.exclusions=**/node_modules/**,**/*.spec.ts,**/coverage/**,**/.angular/**,**/dist/**
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Production') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'npx ng build --configuration=production'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                }
            }
        }
           stage('Push to DockerHub') {
    steps {
        echo '🚀 Pushing image to DockerHub...'
        withCredentials([usernamePassword(credentialsId: 'dockerhub-cred', 
                                          usernameVariable: 'DOCKER_USER', 
                                          passwordVariable: 'DOCKER_PASS')]) {
            dir("${SERVICE_DIR}") {
                unstash 'docker-image'

                // Load the image from tarball
                sh 'docker load -i docker-image.tar'

                // Verify Docker daemon is accessible (fails fast if permission denied)
                sh 'docker info >/dev/null'

                // Tag the image with the Docker Hub username (ensures push permissions)
                sh """
                    docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_USER}/frontend:${DOCKER_TAG}
                """

                // Login to Docker Hub
                sh """
                    echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
                """

                // Push with retry mechanism (up to 3 attempts, 5s delay)
                script {
                    retry(3) {
                        sh """
                            echo "=== Pushing image ${DOCKER_USER}/frontend:${DOCKER_TAG} ==="
                            docker push ${DOCKER_USER}/frontend:${DOCKER_TAG}
                        """
                    }
                }

                // Logout (optional, but good practice)
                sh 'docker logout'

                // Cleanup local images to save disk space
                sh """
                    docker rmi ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_USER}/frontend:${DOCKER_TAG} || true
                """
            }
        }
    }
}
    }

    post {
        failure {
            echo "Frontend CI Pipeline FAILED - Build #${env.BUILD_NUMBER}"
        }
        success {
            echo "Frontend CI Pipeline SUCCESS - Build #${env.BUILD_NUMBER}"
        }
        always {
            cleanWs()
        }
    }
}
