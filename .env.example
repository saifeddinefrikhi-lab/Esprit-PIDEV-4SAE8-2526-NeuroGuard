# ⚠️ SECURITY: This is an example file. Copy to .env and add your real credentials
# NEVER commit .env to version control

# Email Configuration (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-from-google

# Twilio SMS Configuration (Optional - SMS works only if configured)
# Get credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your-account-sid-here
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+1234567890

# Database Configuration (adjust if different)
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=

# Eureka Service Registry
# EUREKA_CLIENT_SERVICE_URL_DEFAULTZONE=http://localhost:8761/eureka/
