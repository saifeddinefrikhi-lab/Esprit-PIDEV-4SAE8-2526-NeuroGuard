pipeline {
    agent any
    triggers {
        githubPush()
    }
    environment {
        GIT_REPO    = 'https://github.com/saifeddinefrikhi-lab/Esprit-PIDEV-4SAE8-2526-NeuroGuard.git'
        GIT_BRANCH  = 'main'
        SONAR_TOKEN = credentials('sonar-token')
        SERVICE_DIR = "neuroguard-backend/reservation-service"
        MAVEN_OPTS  = "-Xmx1024m"
    }
    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }
    stages {
        stage('Code Checkout') {
            steps {
                git branch: "${GIT_BRANCH}",
                    url: "${GIT_REPO}"
            }
        }
        stage('JUnit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "mvn clean test -B -q"
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "${SERVICE_DIR}/target/surefire-reports/*.xml"
                }
            }
        }
        stage('Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "mvn clean package -DskipTests -B -q"
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    withSonarQubeEnv('SonarQube') {
                        sh '''mvn sonar:sonar -B -q \
                            -Dsonar.projectKey=neuroguard-reservation-service \
                            -Dsonar.projectName="NeuroGuard - Reservation Service" \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml'''
                    }
                }
            }
        }
        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
        stage('Trigger CD Pipeline') {
            steps {
                echo '✅ CI passed – triggering CD pipeline...'
                build job: 'reservation-service-CD',
                      parameters: [string(name: 'BUILD_NUMBER_CI', value: "${env.BUILD_NUMBER}")],
                      wait: false
            }
        }
    }
    post {
        always { cleanWs() }
        failure { echo '❌ CI pipeline failed – CD will NOT be triggered.' }
    }
}
