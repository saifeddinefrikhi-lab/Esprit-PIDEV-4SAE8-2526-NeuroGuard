pipeline {
    agent any
    triggers {
        githubPush()
    }
    environment {
        GIT_REPO    = 'https://github.com/saifeddinefrikhi-lab/Esprit-PIDEV-4SAE8-2526-NeuroGuard.git'
        GIT_BRANCH  = 'hamza'
        SONAR_TOKEN = credentials('sonar-token')
        SERVICE_DIR = "neuroguard-backend/careplan-service"
        MAVEN_OPTS  = "-Xmx2048m -XX:+UseG1GC"
    }
    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }
    stages {
        stage('Code Checkout') {
            steps {
                git branch: "${GIT_BRANCH}",
                    url: "${GIT_REPO}"
            }
        }
        stage('Unit Tests + Build') {
            steps {
                timeout(time: 25, unit: 'MINUTES') {
                    echo '🧪 Running tests with JaCoCo coverage...'
                    dir("${SERVICE_DIR}") {
                        sh """mvn clean test package -B \
                            -DforkCount=1 \
                            -Dargument=-DforkCount=1 \
                            -Djacoco.skip=false \
                            -Dmaven.test.failure.ignore=false"""
                    }
                    echo '✅ Tests passed, JaCoCo report generated'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "${SERVICE_DIR}/target/surefire-reports/*.xml"
                    publishHTML([
                        reportDir: "${SERVICE_DIR}/target/site/jacoco",
                        reportFiles: 'index.html',
                        reportName: 'Code Coverage Report',
                        keepAll: true,
                        alwaysLinkToLastBuild: true,
                        allowMissing: true
                    ])
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                timeout(time: 15, unit: 'MINUTES') {
                    dir("${SERVICE_DIR}") {
                        withSonarQubeEnv('SonarQube') {
                            sh """mvn sonar:sonar -B -DskipTests \
                                -Dsonar.projectKey=neuroguard-careplan-service \
                                -Dsonar.projectName=\"NeuroGuard - CarePlan Service\" \
                                -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml \
                                -Dsonar.sources=src/main \
                                -Dsonar.login=${SONAR_TOKEN}"""
                        }
                    }
                }
            }
        }
        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }
        stage('Trigger CD Pipeline') {
            when {
                branch 'hamza'
            }
            steps {
                echo '✅ CI passed – triggering CD pipeline...'
                script {
                    try {
                        def cdJobName = env.JOB_NAME.replaceFirst(/-CI$/, '-CD')
                        def commitSha = sh(returnStdout: true, script: 'git rev-parse HEAD').trim()
                        def buildTag = "${env.BUILD_NUMBER}-${commitSha.take(7)}"
                        
                        build job: cdJobName,
                              parameters: [
                                  string(name: 'DOCKER_TAG', value: buildTag),
                                  string(name: 'BUILD_NUMBER', value: "${env.BUILD_NUMBER}")
                              ],
                              wait: false,
                              propagate: false
                        
                        echo "✓ CD pipeline '${cdJobName}' triggered with tag: ${buildTag}"
                    } catch (Exception e) {
                        echo "⚠ Warning: Could not trigger CD pipeline: ${e.message}"
                        echo "This might be expected if CD job is not configured yet"
                    }
                }
            }
        }
    }
    post {
        always { cleanWs() }
        failure { echo '❌ CI pipeline failed – CD will NOT be triggered.' }
    }
}