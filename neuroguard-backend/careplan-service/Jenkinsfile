pipeline {
    agent any
    triggers {
        githubPush()
    }
    environment {
        GIT_REPO    = 'https://github.com/saifeddinefrikhi-lab/Esprit-PIDEV-4SAE8-2526-NeuroGuard.git'
        GIT_BRANCH  = 'hamza'
        SONAR_TOKEN = credentials('sonar-token')
        SERVICE_DIR = "neuroguard-backend/careplan-service"
        MAVEN_OPTS  = "-Xmx1024m"
    }
    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }
    stages {
        stage('Code Checkout') {
            steps {
                git branch: "${GIT_BRANCH}",
                    url: "${GIT_REPO}"
            }
        }
        stage('JUnit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "mvn clean test -B -DforkCount=0"
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "${SERVICE_DIR}/target/surefire-reports/*.xml"
                    // Vérifier les fichiers générés par JaCoCo
                    script {
                        sh '''
                            echo "Files generated by JaCoCo:"
                            find target -name "jacoco.*" -o -name "*jacoco*" 2>/dev/null | head -20
                        '''
                    }
                }
            }
        }
        stage('Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "mvn package -DskipTests -B"
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        // Vérifier si le rapport JaCoCo existe
                        sh '''
                            echo "Checking for JaCoCo reports..."
                            if [ -f "target/site/jacoco/jacoco.xml" ]; then
                                echo "✓ JaCoCo XML report found"
                                ls -la target/site/jacoco/jacoco.xml
                            else
                                echo "⚠️ JaCoCo XML report NOT found at target/site/jacoco/jacoco.xml"
                                echo "Available files:"
                                find target -name "jacoco*" 2>/dev/null || echo "No jacoco files found"
                            fi
                        '''
                    }
                    withSonarQubeEnv('SonarQube') {
                        sh '''mvn sonar:sonar -B \
                            -Dsonar.projectKey=neuroguard-careplan-service \
                            -Dsonar.projectName="NeuroGuard - CarePlan Service" \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml \
                            -Dsonar.exclusions="**/config/**,**/entity/**,**/dto/**,**/*Dto.java,**/*Entity.java,**/*Config.java"'''
                    }
                }
            }
        }
        stage('Quality Gate') {
            steps {
                timeout(time: 15, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
        stage('Trigger CD Pipeline') {
            steps {
                echo '✅ CI passed – triggering CD pipeline...'
                script {
                    try {
                        // Essayer différents patterns de noms de jobs
                        def cdJobName = null
                        
                        // Pattern 1: Si le job contient le chemin (ex: neuroguard-backend/careplan-service/hamza)
                       if (env.JOB_NAME.contains('/')) {
    cdJobName = env.JOB_NAME.replaceFirst(".*/", "careplan-service/")
} else {
    cdJobName = env.JOB_NAME.replaceAll("(-ci)?\$", "-cd")
}
                        
                        echo "Current Job: ${env.JOB_NAME}"
                        echo "Target CD Job: ${cdJobName}"
                        
                        build job: cdJobName,
                              parameters: [
                                  string(name: 'BUILD_NUMBER', value: "${BUILD_NUMBER}"),
                                  string(name: 'DOCKER_TAG', value: "build-${BUILD_NUMBER}")
                              ],
                              wait: false,
                              propagate: false
                    } catch (Exception e) {
                        echo "⚠️ Erreur lors du déclenchement du CD: ${e.message}"
                        echo "Vérifie que le job CD existe avec le bon nom"
                        // Ne pas échouer le CI si le CD ne peut pas être déclenché
                    }
                }
            }
        }
    }
    post {
        always { cleanWs() }
        success {
            echo '✅ CI pipeline completed successfully'
        }
        failure { 
            echo '❌ CI pipeline failed – CD will NOT be triggered.' 
        }
    }
}