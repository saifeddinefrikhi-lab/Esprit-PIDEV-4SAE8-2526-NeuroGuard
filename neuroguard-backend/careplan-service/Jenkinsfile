pipeline {
    agent any
    triggers {
        githubPush()
    }
    environment {
        GIT_REPO    = 'https://github.com/saifeddinefrikhi-lab/Esprit-PIDEV-4SAE8-2526-NeuroGuard.git'
        GIT_BRANCH  = 'hamza'
        SONAR_TOKEN = credentials('sonar-token')
        SERVICE_DIR = "neuroguard-backend/careplan-service"
        MAVEN_OPTS  = "-Xmx1024m"
    }
    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }
    stages {
        stage('Code Checkout') {
            steps {
                git branch: "${GIT_BRANCH}",
                    url: "${GIT_REPO}"
            }
        }
        stage('JUnit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "mvn clean test -B -DforkCount=0"
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "${SERVICE_DIR}/target/surefire-reports/*.xml"
                }
            }
        }
        stage('Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "mvn package -DskipTests -B"
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    withSonarQubeEnv('SonarQube') {
                        sh '''mvn sonar:sonar -B -q \
                            -Dsonar.projectKey=neuroguard-careplan-service \
                            -Dsonar.projectName="NeuroGuard - CarePlan Service" \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml'''
                    }
                }
            }
        }
        stage('Quality Gate') {
            steps {
                timeout(time: 15, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
        stage('Trigger CD Pipeline') {
            steps {
                echo '✅ CI passed – triggering CD pipeline...'
                script {
                    // Déclenche le pipeline CD après succès du CI
                    def cdJobName = env.JOB_NAME.replaceFirst(/Jenkinsfile$/, 'Jenkinsfile-CD')
                    echo "Triggering job: ${cdJobName}"
                    build job: cdJobName,
                          parameters: [
                              string(name: 'BUILD_NUMBER', value: "${BUILD_NUMBER}"),
                              string(name: 'DOCKER_TAG', value: "build-${BUILD_NUMBER}")
                          ],
                          wait: false,
                          propagate: false
                }
            }
        }
    }
    post {
        always { cleanWs() }
        success {
            echo '✅ CI pipeline completed successfully'
        }
        failure { 
            echo '❌ CI pipeline failed – CD will NOT be triggered.' 
        }
    }
}