pipeline {
    agent any
    
    parameters {
        string(name: 'BUILD_NUMBER_CI', defaultValue: 'latest', description: 'Build number from CI pipeline')
        string(name: 'COMMIT_SHA',      defaultValue: '',       description: 'Exact commit SHA produced by CI')
    }
    
    environment {
        DOCKER_IMAGE = "neuroguard/careplan-service"
        DOCKER_TAG   = "${params.BUILD_NUMBER_CI}"
        SERVICE_DIR  = "neuroguard-backend/careplan-service"
        K8S_DIR      = "neuroguard-backend/k8s/careplan-service"
        GIT_REPO     = 'https://github.com/saifeddinefrikhi-lab/Esprit-PIDEV-4SAE8-2526-NeuroGuard.git'
        GIT_BRANCH   = 'hamza'
        KUBE_NAMESPACE = "neuroguard"
    }
    
    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        skipDefaultCheckout(true)
    }
    
    stages {
        stage('Code Checkout') {
            steps {
                echo "📦 Checking out code from ${GIT_REPO}..."
                git branch: "${GIT_BRANCH}", url: "${GIT_REPO}"
                script {
                    if (params.COMMIT_SHA?.trim()) {
                        echo "🔗 Checking out specific commit: ${params.COMMIT_SHA}"
                        sh "git checkout ${params.COMMIT_SHA}"
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo "🔨 Building Docker image ${DOCKER_IMAGE}:${DOCKER_TAG}..."
                dir("${SERVICE_DIR}") {
                    sh "mvn clean package -DskipTests -B -q"
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                    sh "docker save ${DOCKER_IMAGE}:${DOCKER_TAG} -o docker-image.tar"
                    stash name: 'docker-image', includes: 'docker-image.tar'
                    echo "✓ Docker image built successfully"
                }
            }
        }

        stage('Push to DockerHub') {
    steps {
        echo "📤 Pushing image to DockerHub..."

        unstash 'docker-image'

        withCredentials([usernamePassword(
            credentialsId: 'docker-hub',
            usernameVariable: 'DOCKER_USER',
            passwordVariable: 'DOCKER_PASS'
        )]) {

            dir("${SERVICE_DIR}") {

                sh '''
                    docker load -i docker-image.tar

                    docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} \
                        ${DOCKER_USER}/careplan-service:${DOCKER_TAG}

                    echo "${DOCKER_PASS}" | docker login \
                        -u "${DOCKER_USER}" \
                        --password-stdin
                '''

                retry(3) {
                    sh '''
                        docker push ${DOCKER_USER}/careplan-service:${DOCKER_TAG}
                    '''
                }

                sh '''
                    docker logout

                    docker rmi \
                        ${DOCKER_IMAGE}:${DOCKER_TAG} \
                        ${DOCKER_USER}/careplan-service:${DOCKER_TAG} || true
                '''

                script {
                    env.DOCKERHUB_USER = DOCKER_USER
                }

                echo "✓ Docker image pushed successfully"
            }
        }
    }
}

         stage('Pre-Deployment Checks') {
            steps {
                echo "🔍 Checking Kubernetes cluster..."

                withCredentials([string(
                    credentialsId: 'kubeconfig-b64',
                    variable: 'KUBECONFIG_B64'
                )]) {

                    sh '''
                        echo "$KUBECONFIG_B64" | base64 -d > /tmp/kubeconfig
                        export KUBECONFIG=/tmp/kubeconfig

                        kubectl cluster-info
                        kubectl get nodes
                    '''
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                echo "☸️ Deploying service..."

                withCredentials([string(
                    credentialsId: 'kubeconfig-b64',
                    variable: 'KUBECONFIG_B64'
                )]) {

                    dir("${K8S_DIR}") {

                        sh '''
                            echo "$KUBECONFIG_B64" | base64 -d > /tmp/kubeconfig
                            export KUBECONFIG=/tmp/kubeconfig

                            kubectl get namespace ${KUBE_NAMESPACE} || \
                                kubectl create namespace ${KUBE_NAMESPACE}

                            kubectl apply -f configmap.yaml -n ${KUBE_NAMESPACE}

                            if [ -f secret.yaml ]; then
                                kubectl apply -f secret.yaml -n ${KUBE_NAMESPACE}
                            fi

                            sed -i "s|image: .*careplan-service.*|image: ${DOCKERHUB_USER}/careplan-service:${DOCKER_TAG}|g" deployment.yaml

                            kubectl apply -f deployment.yaml -n ${KUBE_NAMESPACE}

                            if [ -f service.yaml ]; then
                                kubectl apply -f service.yaml -n ${KUBE_NAMESPACE}
                            fi

                            kubectl rollout status deployment/careplan-service \
                                -n ${KUBE_NAMESPACE} --timeout=300s

                            kubectl get pods -n ${KUBE_NAMESPACE}
                            kubectl get svc -n ${KUBE_NAMESPACE}
                        '''
                    }
                }
            }
        }

        stage('Health Check') {
            steps {
                echo "🏥 Health check..."

                withCredentials([string(
                    credentialsId: 'kubeconfig-b64',
                    variable: 'KUBECONFIG_B64'
                )]) {

                    sh '''
                        echo "$KUBECONFIG_B64" | base64 -d > /tmp/kubeconfig
                        export KUBECONFIG=/tmp/kubeconfig

                        READY=$(kubectl get deployment careplan-service \
                            -n ${KUBE_NAMESPACE} \
                            -o jsonpath='{.status.readyReplicas}' || echo 0)

                        DESIRED=$(kubectl get deployment careplan-service \
                            -n ${KUBE_NAMESPACE} \
                            -o jsonpath='{.spec.replicas}' || echo 1)

                        echo "Pods: $READY/$DESIRED"

                        if [ "$READY" = "$DESIRED" ] && [ "$READY" != "0" ]; then
                            echo "✅ Service healthy"
                        else
                            echo "⚠ Service not fully ready"
                        fi
                    '''
                }
            }
        }
    }

    post {
        success {
            echo """
            ✅ =====================================================
            ✅ careplan-service deployed successfully
            ✅ Image: ${DOCKERHUB_USER}/careplan-service:${DOCKER_TAG}
            ✅ Namespace: ${KUBE_NAMESPACE}
            ✅ =====================================================
            """
        }

        failure {
            echo """
            ❌ =====================================================
            ❌ Pipeline FAILED
            ❌ Check logs above
            ❌ =====================================================
            """
        }

        always {
            cleanWs()
        }
    }
}