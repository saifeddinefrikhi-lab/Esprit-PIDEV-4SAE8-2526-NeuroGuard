pipeline {
    agent any
    triggers {
        githubPush()
    }
    environment {
        GIT_REPO     = 'https://github.com/saifeddinefrikhi-lab/Esprit-PIDEV-4SAE8-2526-NeuroGuard.git'
        GIT_BRANCH   = 'main'
        SONAR_TOKEN  = credentials('sonar-token')
        DOCKER_IMAGE = "neuroguard/monitoring-service"
        DOCKER_TAG   = "${env.BUILD_NUMBER}"
        SERVICE_DIR  = "neuroguard-backend/monitoring-service"
        MAVEN_OPTS   = "-Xmx1024m"
    }
    options { timeout(time: 30, unit: 'MINUTES'); disableConcurrentBuilds() }
    stages {
        stage('Code Checkout') {
            steps {
                git branch: "${GIT_BRANCH}",
                    url: "${GIT_REPO}"
            }
        }
        stage('JUnit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "mvn clean test -B -q"
                }
            }
        }
        stage('Build ') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "mvn clean package -DskipTests -q"
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    withSonarQubeEnv('SonarQube') {
                        sh 'mvn sonar:sonar -B -q -Dsonar.projectKey=neuroguard-monitoring-service -Dsonar.projectName="NeuroGuard - Monitoring Service" -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml'
                    }
                }
            }
        }
        stage('Quality Gate') {
            steps { timeout(time: 5, unit: 'MINUTES') { waitForQualityGate abortPipeline: true } }
        }
        stage('Build Docker Image') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} -t ${DOCKER_IMAGE}:latest ."
                    sh "docker save ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_IMAGE}:latest -o docker-image.tar"
                    stash name: 'docker-image', includes: 'docker-image.tar'
                }
            }
        }
        stage('Push to DockerHub') {
            steps {
                echo "🚀 Pushing image to DockerHub..."
                withCredentials([usernamePassword(credentialsId: 'dockerhub-cred', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    dir("${SERVICE_DIR}") {
                        unstash 'docker-image'
                        sh "docker load -i docker-image.tar"
                        sh "docker image inspect ${DOCKER_IMAGE}:${DOCKER_TAG} >/dev/null"
                        sh "docker image inspect ${DOCKER_IMAGE}:latest >/dev/null"
                        sh """
                            echo "=== Login to DockerHub ==="
                            echo "\${DOCKER_PASS}" | docker login -u "\${DOCKER_USER}" --password-stdin

                            echo "=== Pushing image tag ${DOCKER_TAG} ==="
                            docker push ${DOCKER_IMAGE}:${DOCKER_TAG}

                            echo "=== Pushing image tag latest ==="
                            docker push ${DOCKER_IMAGE}:latest

                            echo "=== Logout from DockerHub ==="
                            docker logout
                        """
                    }
                }
            }
        }
    }
    post { always { cleanWs() } }
}