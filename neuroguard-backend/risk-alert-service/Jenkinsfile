pipeline {
    agent any
    triggers {
        githubPush()
    }
    environment {
        GIT_REPO     = 'https://github.com/saifeddinefrikhi-lab/Esprit-PIDEV-4SAE8-2526-NeuroGuard.git'
        GIT_BRANCH   = 'main'
        SONAR_TOKEN  = credentials('sonar-token')
        DOCKER_IMAGE = "neuroguard/risk-alert-service"
        DOCKER_TAG   = "${env.BUILD_NUMBER}"
        SERVICE_DIR  = "neuroguard-backend/risk-alert-service"
        MAVEN_OPTS   = "-Xmx1024m"
    }
    options { timeout(time: 30, unit: 'MINUTES'); disableConcurrentBuilds() }
    stages {
        stage('Code Checkout') {
            steps {
                git branch: "${GIT_BRANCH}",
                    url: "${GIT_REPO}"
            }
        }
        stage('JUnit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "mvn clean test -B -q"
                }
            }
        }
        stage('Build ') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "mvn clean package -DskipTests -q"
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    withSonarQubeEnv('SonarQube') {
                        sh 'mvn sonar:sonar -B -q -Dsonar.projectKey=neuroguard-risk-alert-service -Dsonar.projectName="NeuroGuard - Risk Alert Service" -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml'
                    }
                }
            }
        }
        stage('Quality Gate') {
            steps { timeout(time: 5, unit: 'MINUTES') { waitForQualityGate abortPipeline: true } }
        }
        stage('Build Docker Image') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} -t ${DOCKER_IMAGE}:latest ."
                    sh "docker save ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_IMAGE}:latest -o docker-image.tar"
                    stash name: 'docker-image', includes: 'docker-image.tar'
                }
            }
        }
        stage('Push to DockerHub') {
            steps {
                echo "🚀 Pushing image to DockerHub..."
                withCredentials([usernamePassword(credentialsId: 'dockerhub-cred', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    dir("${SERVICE_DIR}") {
                        unstash 'docker-image'
                        sh "docker load -i docker-image.tar"
                        sh "docker image inspect ${DOCKER_IMAGE}:latest >/dev/null"
                        sh '''
                            set +e
                            for attempt in 1 2 3; do
                                echo "Attempt $attempt/3: Pushing to DockerHub..."
                                echo "=== Login to DockerHub ==="
                                if echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin 2>&1; then
                                    echo "=== Pushing image tag latest ==="
                                    if docker push ${DOCKER_IMAGE}:latest; then
                                        echo "=== Logout from DockerHub ==="
                                        docker logout
                                        set -e
                                        exit 0
                                    fi
                                fi
                                if [ $attempt -lt 3 ]; then
                                    echo "Push failed. Waiting 20 seconds before retry..."
                                    sleep 20
                                fi
                            done
                            set -e
                            echo "All 3 push attempts failed"
                            exit 1
                        '''
                    }
                }
            }
        }
    }
    post { always { cleanWs() } }
}