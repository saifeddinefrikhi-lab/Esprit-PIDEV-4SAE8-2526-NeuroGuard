pipeline {
    agent any
    triggers {
        githubPush()
    }
    environment {
        GIT_REPO    = 'https://github.com/saifeddinefrikhi-lab/Esprit-PIDEV-4SAE8-2526-NeuroGuard.git'
        GIT_BRANCH  = 'hamza'
        SONAR_TOKEN = credentials('sonar-token')
        SERVICE_DIR = "neuroguard-backend/prescription-service"
        MAVEN_OPTS  = "-Xmx2048m -XX:+UseG1GC"
    }
    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }
    stages {
        stage('Code Checkout') {
            steps {
                git branch: "${GIT_BRANCH}",
                    url: "${GIT_REPO}"
            }
        }
        stage('Unit Tests + Build') {
    steps {
        timeout(time: 25, unit: 'MINUTES') {
            echo '🧪 Running tests with JaCoCo coverage...'
            dir("${SERVICE_DIR}") {
                sh """
                mvn clean test package -B \
                    -DforkCount=1 \
                    -Dargument=-DforkCount=1 \
                    -Djacoco.skip=false \
                    -Dmaven.test.failure.ignore=false \
                    -Dtest='!*ApplicationTests' \
                    -DskipITs
                """
            }
            echo '✅ Tests passed, JaCoCo report generated'
        }
    }
    post {
        always {
            junit allowEmptyResults: true,
                  testResults: "${SERVICE_DIR}/target/surefire-reports/*.xml"

            publishHTML([
                reportDir: "${SERVICE_DIR}/target/site/jacoco",
                reportFiles: 'index.html',
                reportName: 'JaCoCo Code Coverage Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: true
            ])
        }
    }
}
        stage('SonarQube Analysis') {
            steps {
                timeout(time: 15, unit: 'MINUTES') {
                    dir("${SERVICE_DIR}") {
                        withSonarQubeEnv('SonarQube') {
                            sh """mvn sonar:sonar -B -DskipTests \
                                -Dsonar.projectKey=neuroguard-prescription-service \
                                -Dsonar.projectName=\"NeuroGuard - Prescription Service\" \
                                -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml \
                                -Dsonar.sources=src/main \
                                -Dsonar.exclusions=src/test/**/*.* \
                                -Dsonar.login=${SONAR_TOKEN}"""
                        }
                    }
                }
            }
        }
        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }
        stage('Trigger CD Pipeline') {  
    steps {
        echo '✅ CI passed – triggering CD pipeline...'

        script {
            try {
                def cdJobName = 'prescription-service-CD'

                def commitSha = sh(
                    returnStdout: true,
                    script: 'git rev-parse HEAD'
                ).trim()

                build job: cdJobName,
                    parameters: [
                        string(name: 'BUILD_NUMBER_CI', value: "${env.BUILD_NUMBER}"),
                        string(name: 'COMMIT_SHA', value: commitSha)
                    ],
                    wait: false,
                    propagate: false

                echo "✓ CD pipeline '${cdJobName}' triggered successfully"

            } catch (Exception e) {
                echo "⚠ Could not trigger CD pipeline: ${e.message}"
            }
        }
    }
}
    }
    post {
        always { cleanWs() }
        failure { echo '❌ CI pipeline failed – CD will NOT be triggered.' }
    }
}