pipeline {
    agent any
    triggers {
        githubPush()
    }
    environment {
        GIT_REPO     = 'https://github.com/saifeddinefrikhi-lab/Esprit-PIDEV-4SAE8-2526-NeuroGuard.git'
        GIT_BRANCH   = 'ameni'
        SONAR_TOKEN  = credentials('sonar-token')
        DOCKER_IMAGE = "neuroguard/eureka-server"
        DOCKER_TAG   = "${env.BUILD_NUMBER}"
        SERVICE_DIR  = "neuroguard-backend/eureka-server"
        MAVEN_OPTS   = "-Xmx512m"
    }
    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }
    stages {

        stage('Code Checkout') {
            steps {
                git branch: "${GIT_BRANCH}", url: "${GIT_REPO}"
            }
        }

        stage('Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "mvn clean package -DskipTests -B -q"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            mvn sonar:sonar -B -q \
                                -Dsonar.projectKey=neuroguard-eureka-server \
                                -Dsonar.projectName="NeuroGuard - Eureka Server" \
                                -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                    sh "docker save ${DOCKER_IMAGE}:${DOCKER_TAG} -o docker-image.tar"
                    stash name: 'docker-image', includes: 'docker-image.tar'
                }
            }
        }

        stage('Push to DockerHub') {
            steps {
                echo '🚀 Pushing image to DockerHub...'
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    dir("${SERVICE_DIR}") {
                        unstash 'docker-image'
                        sh 'docker load -i docker-image.tar'
                        sh 'docker info >/dev/null'
                        sh "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} \${DOCKER_USER}/eureka-server:${DOCKER_TAG}"
                        sh 'echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin'
                        retry(3) {
                            sh "docker push \${DOCKER_USER}/eureka-server:${DOCKER_TAG}"
                        }
                        sh 'docker logout'
                        sh "docker rmi ${DOCKER_IMAGE}:${DOCKER_TAG} \${DOCKER_USER}/eureka-server:${DOCKER_TAG} || true"
                        script { env.DOCKERHUB_USER = DOCKER_USER }
                    }
                }
            }
        }
    }

    post {
        always  { cleanWs() }
        success {
            echo "✅ Eureka Server CI passed — triggering CD..."
            build job: 'CD_EurekaServer',
                  parameters: [string(name: 'BUILD_NUMBER_CI', value: "${DOCKER_TAG}")],
                  wait: false
        }
        failure { echo '❌ Eureka Server CI failed.' }
    }
}