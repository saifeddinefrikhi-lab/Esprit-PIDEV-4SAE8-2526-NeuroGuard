pipeline {
    agent any
    parameters {
        string(name: 'BUILD_NUMBER_CI', defaultValue: 'latest', description: 'Build tag from CI pipeline')
    }
    environment {
        DOCKER_IMAGE = "neuroguard/eureka-server"
        DOCKER_TAG   = "${params.BUILD_NUMBER_CI}"
        SERVICE_DIR  = "neuroguard-backend/eureka-server"
        GIT_REPO     = 'https://github.com/saifeddinefrikhi-lab/Esprit-PIDEV-4SAE8-2526-NeuroGuard.git'
        GIT_BRANCH   = 'ameni'
    }
    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        skipDefaultCheckout(true)
    }
    stages {

        stage('Code Checkout') {
            steps {
                git branch: "${GIT_BRANCH}", url: "${GIT_REPO}"
            }
        }

        stage('Deploy Eureka to Kubernetes') {
            steps {
                echo '☸️ Deploying Eureka Server to Kubernetes...'
                withCredentials([string(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_B64')]) {
                    dir("${SERVICE_DIR}/k8s") {
                        sh """
                            echo "\$KUBECONFIG_B64" | base64 -d > /tmp/kubeconfig
                            export KUBECONFIG=/tmp/kubeconfig

                            # Verify cluster
                            kubectl --insecure-skip-tls-verify get nodes

                            # Create namespace if not exists
                            kubectl --insecure-skip-tls-verify get namespace neuroguard 2>/dev/null || \
                            kubectl --insecure-skip-tls-verify create namespace neuroguard

                            # Apply configmap and secret
                            kubectl --insecure-skip-tls-verify apply -f configmap.yaml --namespace=neuroguard
                            kubectl --insecure-skip-tls-verify apply -f secret.yaml    --namespace=neuroguard

                            # Update image in deployment.yaml
                            sed -i "s|image: .*eureka-server.*|image: \${DOCKERHUB_USER}/eureka-server:${DOCKER_TAG}|" deployment.yaml

                            # Delete existing deployment to force fresh rollout
                            kubectl --insecure-skip-tls-verify delete deployment eureka-server \
                                --namespace=neuroguard --ignore-not-found=true
                            sleep 5

                            # Apply manifests
                            kubectl --insecure-skip-tls-verify apply -f deployment.yaml --namespace=neuroguard
                            kubectl --insecure-skip-tls-verify apply -f service.yaml    --namespace=neuroguard

                            # Wait for rollout
                            kubectl --insecure-skip-tls-verify rollout status deployment/eureka-server \
                                --namespace=neuroguard --timeout=300s || {
                                echo "❌ Eureka rollout failed. Debugging..."
                                kubectl --insecure-skip-tls-verify get pods -n neuroguard
                                kubectl --insecure-skip-tls-verify describe pod -l app=eureka-server -n neuroguard
                                kubectl --insecure-skip-tls-verify logs -l app=eureka-server -n neuroguard --tail=50 || true
                                rm -f /tmp/kubeconfig
                                exit 1
                            }

                            echo ""
                            echo "✅ Eureka Server deployed successfully!"
                            kubectl --insecure-skip-tls-verify get pods --namespace=neuroguard
                            kubectl --insecure-skip-tls-verify get services --namespace=neuroguard

                            rm -f /tmp/kubeconfig
                        """
                    }
                }
            }
        }
    }

    post {
        always  { cleanWs() }
        success { echo '✅ Eureka Server deployed successfully.' }
        failure { echo '❌ Eureka Server CD failed.' }
    }
}