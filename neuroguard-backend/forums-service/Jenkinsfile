pipeline {
    agent any

    triggers {
        githubPush()
    }

    environment {
        SERVICE_DIR = 'neuroguard-backend/forums-service'

        SONAR_TOKEN = credentials('sonar-token')

        DOCKER_IMAGE = 'neuroguard/forum-service'
        DOCKER_TAG   = "${env.BUILD_NUMBER}"

        MAVEN_OPTS = '-Xmx1024m'
        JAVA_HOME  = '/usr/lib/jvm/java-17-openjdk-amd64'
        PATH       = "${JAVA_HOME}/bin:${env.PATH}"

        KUBECONFIG = '/home/damiano/.kube/config'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {
        stage('Check Tools') {
            steps {
                sh 'git branch -a'
                sh 'git log -1 --oneline'
                sh 'java -version'
                sh 'mvn -version'
                sh 'docker --version'
                sh 'kubectl get nodes'
                sh 'helm version || true'
            }
        }

        stage('Test + JaCoCo + Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'mvn clean test jacoco:report package -B'
                    sh 'ls -l target/site/jacoco/'
                    sh 'test -f target/site/jacoco/jacoco.xml'
                    sh 'test -f target/site/jacoco/index.html'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${SERVICE_DIR}") {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            mvn sonar:sonar -B \
                            -Dsonar.projectKey=neuroguard-forum-service \
                            -Dsonar.projectName="NeuroGuard - Forum Service" \
                            -Dsonar.login=$SONAR_TOKEN \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        '''
                    }
                }
            }
        }

        stage('Publish JaCoCo Report') {
            steps {
                publishHTML(target: [
                    reportDir: "${SERVICE_DIR}/target/site/jacoco",
                    reportFiles: 'index.html',
                    reportName: 'JaCoCo Coverage Report',
                    keepAll: true,
                    alwaysLinkToLastBuild: true,
                    allowMissing: false
                ])
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                    sh "docker save ${DOCKER_IMAGE}:${DOCKER_TAG} -o docker-image.tar"
                    stash name: 'docker-image', includes: 'docker-image.tar'
                }
            }
        }

        stage('Push to DockerHub') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-cred',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {
                    dir("${SERVICE_DIR}") {
                        unstash 'docker-image'
                        sh 'docker load -i docker-image.tar'
                        sh "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_USER}/forum-service:${DOCKER_TAG}"
                        sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin'

                        retry(3) {
                            sh "docker push ${DOCKER_USER}/forum-service:${DOCKER_TAG}"
                        }

                        sh 'docker logout'
                        sh "docker rmi ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_USER}/forum-service:${DOCKER_TAG} || true"
                    }
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-cred',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {
                    dir("${SERVICE_DIR}") {
                        sh 'kubectl apply -f k8s/mysql.yaml'
                        sh 'kubectl apply -f k8s/deployment.yaml'
                        sh 'kubectl apply -f k8s/service.yaml'
                        sh 'kubectl apply -f k8s/servicemonitor.yaml'

                        sh "kubectl set image deployment/forum-service forum-service=${DOCKER_USER}/forum-service:${DOCKER_TAG}"

                        sh 'kubectl rollout status deployment/forum-service --timeout=180s'
                        sh 'kubectl get pods'
                        sh 'kubectl get svc'
                    }
                }
            }
        }

        stage('Verify Prometheus Monitoring') {
            steps {
                sh 'kubectl get servicemonitor -n monitoring || true'
                sh 'kubectl get pods -n monitoring || true'
                sh 'kubectl get svc -n monitoring || true'
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }

        failure {
            echo 'Pipeline failed!'
        }

        always {
            cleanWs()
        }
    }
}