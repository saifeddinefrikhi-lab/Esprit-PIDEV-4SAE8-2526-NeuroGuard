pipeline {
    agent any
    parameters {
        string(name: 'BUILD_NUMBER_CI', defaultValue: 'latest', description: 'Build number from CI pipeline')
        string(name: 'COMMIT_SHA',      defaultValue: '',       description: 'Exact commit SHA produced by CI')
    }
    environment {
        DOCKER_IMAGE = "neuroguard/consultation-service"
        DOCKER_TAG   = "${params.BUILD_NUMBER_CI}"
        SERVICE_DIR  = "neuroguard-backend/consultation-service"
        GIT_REPO     = 'https://github.com/saifeddinefrikhi-lab/Esprit-PIDEV-4SAE8-2526-NeuroGuard.git'
        GIT_BRANCH   = 'ameni'
    }
    options {
        timeout(time: 60, unit: 'MINUTES')
        disableConcurrentBuilds()
        skipDefaultCheckout(true)
    }
    stages {

        stage('Code Checkout') {
            steps {
                git branch: "${GIT_BRANCH}", url: "${GIT_REPO}"
                script {
                    if (params.COMMIT_SHA?.trim()) {
                        sh "git checkout ${params.COMMIT_SHA}"
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "mvn clean package -DskipTests -B -q"
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                    sh "docker save ${DOCKER_IMAGE}:${DOCKER_TAG} -o docker-image.tar"
                    stash name: 'docker-image', includes: 'docker-image.tar'
                }
            }
        }

        stage('Push to DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    dir("${SERVICE_DIR}") {
                        unstash 'docker-image'
                        sh 'docker load -i docker-image.tar'
                        sh "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} \${DOCKER_USER}/consultation-service:${DOCKER_TAG}"
                        sh 'echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin'
                        retry(3) {
                            sh "docker push \${DOCKER_USER}/consultation-service:${DOCKER_TAG}"
                        }
                        sh 'docker logout'
                        sh "docker rmi ${DOCKER_IMAGE}:${DOCKER_TAG} \${DOCKER_USER}/consultation-service:${DOCKER_TAG} || true"
                        script { env.DOCKERHUB_USER = DOCKER_USER }
                    }
                }
            }
        }

        stage('Deploy to Kubernetes') {
    steps {
        echo '☸️ Deploying to Kubernetes (kubeadm)...'
        withCredentials([string(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_B64')]) {
            dir("${SERVICE_DIR}/k8s") {
                sh """
                    echo "\$KUBECONFIG_B64" | base64 -d > /tmp/kubeconfig
                    export KUBECONFIG=/tmp/kubeconfig

                    kubectl --insecure-skip-tls-verify get nodes

                    # Create namespace if not exists
                    kubectl --insecure-skip-tls-verify get namespace neuroguard 2>/dev/null || \
                    kubectl --insecure-skip-tls-verify create namespace neuroguard

                    # ── 0. Storage ────────────────────────────────────
                    echo "💾 Creating Persistent Volume..."
                    kubectl --insecure-skip-tls-verify apply -f mysql-pv.yaml
                    kubectl --insecure-skip-tls-verify apply -f mysql-pvc.yaml --namespace=neuroguard

                    # Check PVC status directly instead of using wait
                    sleep 5
                    PVC_STATUS=\$(kubectl --insecure-skip-tls-verify get pvc mysql-pvc \
                        --namespace=neuroguard \
                        -o jsonpath='{.status.phase}')
                    echo "PVC Status: \$PVC_STATUS"

                    if [ "\$PVC_STATUS" != "Bound" ]; then
                        echo "❌ PVC not bound. Status: \$PVC_STATUS"
                        kubectl --insecure-skip-tls-verify describe pvc mysql-pvc -n neuroguard
                        rm -f /tmp/kubeconfig
                        exit 1
                    fi
                    echo "✅ PVC bound successfully"

                    # ── 1. Deploy MySQL ──────────────────────────────────
                    echo "🗄️ Deploying MySQL..."
                    # Delete existing deployment to force fresh rollout
                    kubectl --insecure-skip-tls-verify delete deployment mysql \
                        --namespace=neuroguard --ignore-not-found=true
                    sleep 5
                    kubectl --insecure-skip-tls-verify apply -f mysql-deployment.yaml --namespace=neuroguard
                    kubectl --insecure-skip-tls-verify rollout status deployment/mysql \
                        --namespace=neuroguard --timeout=300s || {
                        echo "❌ MySQL failed. Debugging..."
                        kubectl --insecure-skip-tls-verify get pods -n neuroguard
                        kubectl --insecure-skip-tls-verify describe pod -l app=mysql -n neuroguard
                        kubectl --insecure-skip-tls-verify logs -l app=mysql -n neuroguard --tail=30 || true
                        rm -f /tmp/kubeconfig
                        exit 1
                    }
                    echo "✅ MySQL is running"

                    # ── 2. Deploy Redis ──────────────────────────────────
                    echo "🔴 Deploying Redis..."
                    kubectl --insecure-skip-tls-verify apply -f redis-deployment.yaml --namespace=neuroguard
                    kubectl --insecure-skip-tls-verify rollout status deployment/redis \
                        --namespace=neuroguard --timeout=180s || {
                        echo "❌ Redis failed. Debugging..."
                        kubectl --insecure-skip-tls-verify get pods -n neuroguard
                        kubectl --insecure-skip-tls-verify describe pod -l app=redis -n neuroguard
                        kubectl --insecure-skip-tls-verify logs -l app=redis -n neuroguard --tail=30 || true
                        rm -f /tmp/kubeconfig
                        exit 1
                    }
                    echo "✅ Redis is running"

                    # ── 3. Deploy Eureka ─────────────────────────────────
                    echo "🔍 Deploying Eureka..."
                    kubectl --insecure-skip-tls-verify apply -f eureka-deployment.yaml --namespace=neuroguard
                    kubectl --insecure-skip-tls-verify rollout status deployment/eureka-server \
                        --namespace=neuroguard --timeout=300s || {
                        echo "❌ Eureka failed. Debugging..."
                        kubectl --insecure-skip-tls-verify get pods -n neuroguard
                        kubectl --insecure-skip-tls-verify describe pod -l app=eureka-server -n neuroguard
                        kubectl --insecure-skip-tls-verify logs -l app=eureka-server -n neuroguard --tail=30 || true
                        rm -f /tmp/kubeconfig
                        exit 1
                    }
                    echo "✅ Eureka is running"

                    # ── 4. Deploy Consultation Service ───────────────────
                    echo "🏥 Deploying Consultation Service..."
                    kubectl --insecure-skip-tls-verify apply -f configmap.yaml --namespace=neuroguard
                    kubectl --insecure-skip-tls-verify apply -f secret.yaml    --namespace=neuroguard

                    sed -i "s|image: .*consultation-service.*|image: ${env.DOCKERHUB_USER}/consultation-service:${DOCKER_TAG}|" deployment.yaml

                    kubectl --insecure-skip-tls-verify apply -f deployment.yaml --namespace=neuroguard
                    kubectl --insecure-skip-tls-verify apply -f service.yaml    --namespace=neuroguard

                    kubectl --insecure-skip-tls-verify rollout status deployment/consultation-service \
                        --namespace=neuroguard --timeout=600s || {
                        echo "❌ Consultation Service rollout failed. Debugging..."
                        kubectl --insecure-skip-tls-verify get pods -n neuroguard
                        kubectl --insecure-skip-tls-verify describe pod -l app=consultation-service -n neuroguard
                        kubectl --insecure-skip-tls-verify logs -l app=consultation-service -n neuroguard --tail=50 || true
                        rm -f /tmp/kubeconfig
                        exit 1
                    }

                    # ── Final Status ─────────────────────────────────────
                    echo ""
                    echo "✅ All services deployed successfully!"
                    echo ""
                    kubectl --insecure-skip-tls-verify get pods --namespace=neuroguard
                    echo ""
                    kubectl --insecure-skip-tls-verify get services --namespace=neuroguard
                    echo ""
                    kubectl --insecure-skip-tls-verify get pvc --namespace=neuroguard
                    echo ""
                    echo "🌐 Consultation Service: http://192.168.33.10:30090"

                    rm -f /tmp/kubeconfig
                """
            }
        }
    }
}
    }

    post {
        always  { cleanWs() }
        success { echo '✅ consultation-service deployed successfully.' }
        failure { echo '❌ CD pipeline failed.' }
    }
}